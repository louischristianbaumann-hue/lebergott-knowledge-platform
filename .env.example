# Lebergott Knowledge Platform — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git

# ─── Required ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-32-char-random-secret-here

# InfraNodus API key from https://infranodus.com/settings
INFRANODUS_API_KEY=your-infranodus-api-key

# n8n webhook URL for Lebergott Bot workflow
N8N_WEBHOOK_URL=https://your-n8n-instance.up.railway.app/webhook/lebergott-bot

# Bearer token for n8n webhook auth (set in n8n workflow settings)
N8N_AUTH_TOKEN=your-n8n-auth-token

# ─── Optional ────────────────────────────────────────────────
# Database (defaults to SQLite — use PostgreSQL for production)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/lebergott

# CORS origins — JSON array OR comma-separated (add your Vercel frontend URL)
# CORS_ORIGINS=["https://lebergott-knowledge-platform.vercel.app","http://localhost:5173"]
# CORS_ORIGINS=https://lebergott-knowledge-platform.vercel.app,http://localhost:5173

# CORS regex for Vercel preview URLs (default matches *-louischristianbaumann-hue.vercel.app)
# CORS_ORIGIN_REGEX=https://.*-louischristianbaumann-hue\.vercel\.app

# App settings
DEBUG=false
ENVIRONMENT=production

# InfraNodus username (your InfraNodus account)
INFRANODUS_USERNAME=lautloos

# ─── Frontend (Vite) ─────────────────────────────────────────
# Set in Vercel dashboard or .env.local for local dev
VITE_API_URL=http://localhost:8000
